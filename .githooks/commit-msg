#!/usr/bin/env bash
# Enforces Conventional Commits format on vault-only commits.
# Activate once per clone: git config core.hooksPath .githooks
set -e

msg_file="$1"
first_line=$(head -n1 "$msg_file")

# Allow merge commits and reverts
if [[ "$first_line" =~ ^(Merge|Revert) ]]; then
  exit 0
fi

pattern='^(feat|fix|docs|chore|refactor|test|perf|ci|style|build)(\(.+\))?!?: .+'

if [[ ! "$first_line" =~ $pattern ]]; then
  echo "ERROR: Commit message does not follow Conventional Commits." >&2
  echo "" >&2
  echo "Got:      $first_line" >&2
  echo "Expected: <type>(<scope>)?: <description>" >&2
  echo "Types:    feat | fix | docs | chore | refactor | test | perf | ci | style | build" >&2
  echo "Example:  feat(graph): enable directional arrows" >&2
  exit 1
fi

exit 0
